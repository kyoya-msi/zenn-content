@startuml
title <size:24>Container View: WEBシステム(分離構成)</size>\n<size:24>RESTAPI:フロントエンドとバックエンドが分離</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

Person(ユーザー, "ユーザー", $descr="ブラウザを通じてシステムを利用", $tags="", $link="")

System_Boundary("WEBシステム分離構成_boundary", "WEBシステム(分離構成)", $tags="") {
  AddBoundaryTag("WEBサーバー", $borderColor="#cccccc", $fontColor="#cccccc", $borderStyle="dashed")
  Boundary(group_1, "WEBサーバー", $tags="WEBサーバー") {
    Container(WEBシステム分離構成.バックエンド, "バックエンド", $techn="SpringBoot(RESTAPI)", $descr="ビジネスロジックの実行とJSONデータ提供", $tags="", $link="")
  }

  AddBoundaryTag("クライアント(ブラウザ)", $borderColor="#cccccc", $fontColor="#cccccc", $borderStyle="dashed")
  Boundary(group_2, "クライアント(ブラウザ)", $tags="クライアント(ブラウザ)") {
    Container(WEBシステム分離構成.フロントエンド, "フロントエンド", $techn="Reactなど", $descr="ユーザー操作の制御と画面の構築", $tags="", $link="")
  }

  Container(WEBシステム分離構成.データベース, "データベース", $techn="RDBMS", $descr="データの永続化", $tags="", $link="")
}

Rel(ユーザー, WEBシステム分離構成.フロントエンド, "画面操作", $techn="", $tags="", $link="")
Rel(WEBシステム分離構成.フロントエンド, WEBシステム分離構成.バックエンド, "API呼び出し", $techn="HTTP/JSON", $tags="", $link="")
Rel(WEBシステム分離構成.バックエンド, WEBシステム分離構成.データベース, "JDBC/SQL", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml