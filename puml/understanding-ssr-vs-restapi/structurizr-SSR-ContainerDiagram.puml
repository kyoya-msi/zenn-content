@startuml
title <size:24>Container View: WEBシステム(SSR構成)</size>\n<size:24>SSR:画面とバックエンドが一体化</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

Person(ユーザー, "ユーザー", $descr="ブラウザを通じてシステムを利用", $tags="", $link="")

System_Boundary("WEBシステムSSR構成_boundary", "WEBシステム(SSR構成)", $tags="") {
  Container(WEBシステムSSR構成.WEBアプリケーション, "WEBアプリケーション", $techn="SpringBoot(SpringMVC)", $descr="ビジネスロジック実行とHTML画面の提供", $tags="", $link="")
  Container(WEBシステムSSR構成.データベース, "データベース", $techn="RDBMS", $descr="データの永続化", $tags="", $link="")
}

Rel(WEBシステムSSR構成.WEBアプリケーション, WEBシステムSSR構成.データベース, "JDBC/SQL", $techn="", $tags="", $link="")
Rel(ユーザー, WEBシステムSSR構成.WEBアプリケーション, "画面操作/HTTPリクエスト", $techn="HTTP/HTML", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml